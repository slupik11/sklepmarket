# ==============================
# KupSklep.pl — Zmienne środowiskowe
# Skopiuj do .env.local i uzupełnij
# ==============================

# Supabase — znajdziesz w: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://twoj-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key — tylko po stronie serwera (admin actions)
# Znajdziesz w: Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — do wysyłania emaili (https://resend.com)
# Utwórz konto i API key w: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Panel admina — hasło do logowania (ustaw własne!)
ADMIN_PASSWORD=zmien-to-na-bezpieczne-haslo

# Domena (opcjonalnie, dla Vercel)
NEXT_PUBLIC_SITE_URL=https://kupsklep.pl
